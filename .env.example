# Gmail SMTP credentials
# Use a Gmail App Password (not your regular password).
# Enable at: https://myaccount.google.com/apppasswords
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your-16-char-app-password

# Where to send job alert emails (defaults to SMTP_USER if not set)
NOTIFY_EMAIL=you@example.com

# SMTP server settings (defaults work for Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# How often to check all websites (in hours, default 6)
CHECK_INTERVAL_HOURS=6

# PostgreSQL connection string
DATABASE_URL=oops